# ─── Twilio (Voice + SMS) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Deepgram (STT) ────────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ElevenLabs (TTS) ──────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LLM ────────────────────────────────────────────────────────────
# Primary: Groq. Verify model exists: curl api.groq.com/openai/v1/models
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fallback: OpenAI (per-call circuit breaker)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model name from Groq — DO NOT hardcode, verify before deploy
LLM_MODEL=llama-3.3-70b-versatile

# ─── Vercel Integration ────────────────────────────────────────────
# Your Vercel app URL (no trailing slash)
VERCEL_API_URL=https://godscrew.vercel.app
# Shared secret for voice server ↔ Vercel auth (32+ chars)
AGENT_SECRET=change-me-to-a-random-32-char-string

# ─── Redis (Payment Events) ────────────────────────────────────────
# Upstash Redis URL (rediss:// for TLS)
UPSTASH_REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379

# ─── Cartesia (TTS — primary) ──────────────────────────────────────
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxx
CARTESIA_VOICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Google Gemini (Fallback LLM) ──────────────────────────────────
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (Email) ─────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (Payments) ──────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ─────────────────────────────────────────────────────────
SERVER_BASE_URL=https://your-domain.com
PORT=8080

# ─── Optional ───────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# MAX_CONCURRENT_CALLS=10
# MAX_CALL_DURATION=300
# SILENCE_TIMEOUT=25
# SILENCE_EXIT_TIMEOUT=35
